{
  "id": null,
  "uid": "routeforge-provider",
  "title": "RouteForge Provider Metrics",
  "tags": ["routeforge", "providers"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Requests by Provider (5m)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (provider) (rate(routeforge_provider_requests_total[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency p95 (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, provider) (rate(routeforge_provider_latency_ms_bucket[5m])))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latest Throughput (tok/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "routeforge_provider_throughput_tps",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Computed Uptime %",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "routeforge_provider_uptime_pct",
          "refId": "A"
        }
      ]
    }
  ]
}
